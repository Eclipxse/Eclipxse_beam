export global Theme {
    in property <brush> canvas: #0c0d11;
    in property <brush> sidebar: #0f1015;
    in property <brush> surface: #14161c;
    in property <brush> surface-raised: #191b23;
    in property <brush> surface-hover: #20232d;
    in property <brush> line: #292c36;
    in property <brush> line-soft: #20232b;
    in property <brush> text: #f2f2f4;
    in property <brush> text-muted: #9297a3;
    in property <brush> text-faint: #646a76;
    in property <brush> accent: #8b7cff;
    in property <brush> accent-hover: #9d91ff;
    in property <brush> accent-soft: #8b7cff20;
    in property <brush> success: #68d7a1;
    in property <brush> success-soft: #68d7a118;
    in property <brush> danger: #ff7185;
    in property <brush> danger-soft: #ff71851a;
    in property <brush> warning: #e7b56a;
}

export global Metrics {
    in property <length> radius-small: 8px;
    in property <length> radius: 12px;
    in property <length> radius-large: 16px;
    in property <length> control-height: 42px;
}
