export global Theme {
    // Approved warm palette
    in property <brush> cream: #f7f1de;
    in property <brush> sage: #b0ba99;
    in property <brush> caramel: #9d6638;
    in property <brush> espresso: #4e220f;

    // Espresso-derived surfaces keep the palette usable in a dark desktop UI.
    in property <brush> backdrop: #120a06;
    in property <brush> canvas: #1a0e09;
    in property <brush> surface: #21120c;
    in property <brush> surface-soft: #f7f1de08;
    in property <brush> surface-hover: #f7f1de0d;
    in property <brush> surface-active: #9d663824;
    in property <brush> edge: #f7f1de1e;
    in property <brush> divider: #f7f1de12;

    in property <brush> text: #f7f1de;
    in property <brush> text-muted: #c2b9a6;
    in property <brush> text-faint: #817568;
    in property <brush> accent: #9d6638;
    in property <brush> accent-hover: #b77742;
    in property <brush> accent-soft: #9d663826;
    in property <brush> success: #b0ba99;
    in property <brush> success-soft: #b0ba991c;
    in property <brush> danger: #d98d78;
    in property <brush> danger-soft: #d98d7818;
}

export global Metrics {
    in property <length> radius-small: 8px;
    in property <length> radius: 12px;
    in property <length> radius-large: 18px;
    in property <length> title-height: 72px;
    in property <length> content-padding: 34px;
    in property <length> control-height: 42px;
}
