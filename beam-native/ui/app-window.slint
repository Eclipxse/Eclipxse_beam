                    }
                    Text {
                        text: "Keep Eclipxse Beam open while pairing";
                        color: Theme.text-faint;
                        font-family: "Segoe UI";
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.divider;
            }

            Rectangle {
                width: 410px;
                background: #00000000;
                VerticalLayout {
                    spacing: 0px;
                    SectionLabel { label: "HOW IT WORKS"; }
                    StepRow { number: "1"; title: "Scan the code"; detail: "Open the secure Beam companion."; }
                    StepRow { number: "2"; title: "Choose your files"; detail: "Pick anything from your phone."; }
                    StepRow { number: "3"; title: "Accept the transfer"; detail: "Confirm it here and keep both devices close."; }
                    Rectangle {
                        height: 82px;
                        border-radius: Metrics.radius;
                        background: Theme.surface-soft;
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
