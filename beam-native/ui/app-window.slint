component TransferView inherits Rectangle {
    in-out property <bool> paused: false;
    min-height: 688px;
    max-width: 10000px;
    max-height: 10000px;
    background: Theme.canvas;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: Metrics.content-padding;
        padding-right: Metrics.content-padding;
        padding-top: 20px;
        spacing: 0px;

        Rectangle {
            height: 122px;
            border-radius: Metrics.radius;
            background: Theme.surface-soft;
            VerticalLayout {
                padding: 18px;
                spacing: 12px;
                HorizontalLayout {
                    spacing: 10px;
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: root.paused ? "Transfer paused" : "Sending to Galaxy S24";
                            color: Theme.text;
                            font-family: "Segoe UI";
                            font-size: 17px;
                            font-weight: 650;
                            vertical-alignment: bottom;
                        }
                        Text {
                            text: root.paused ? "Your progress is saved" : "164.2 MB of 248 MB";
                            color: Theme.text-muted;
                            font-family: "Segoe UI";
                            font-size: 11px;
                            vertical-alignment: top;
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: "66%";
                        color: Theme.caramel;
                        font-family: "Segoe UI";
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }
                ProgressBar { value: 0.66; height: 7px; }
                HorizontalLayout {
                    Text {
                        text: root.paused ? "Ready to resume" : "38.4 MB/s";
                        color: Theme.text-faint;
                        font-family: "Segoe UI";
                        font-size: 10px;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: root.paused ? "—" : "About 3 seconds left";
                        color: Theme.text-faint;
                        font-family: "Segoe UI";
                        font-size: 10px;
                    }
                }
            }
        }

        Rectangle { height: 14px; }

        HorizontalLayout {
            vertical-stretch: 1;
            max-height: 10000px;
            spacing: 26px;

            VerticalLayout {
                horizontal-stretch: 1;
                max-width: 10000px;
                spacing: 0px;
                SectionLabel { label: "TRANSFER QUEUE"; meta: "2 of 3 files"; }
                TransferRow {
                    thumb-kind: 0;
                    name: "Midnight in Kyoto.mov";
                    detail: "184.2 MB · Sending now";
                    percent: "78%";
                    progress: 0.78;
                }
                TransferRow {
                    thumb-kind: 1;
                    name: "Brand assets.zip";
                    detail: "63.8 MB · Waiting";
                    percent: "0%";
                    progress: 0;
                }
                TransferRow {
                    thumb-kind: 2;
                    name: "beam-cover.png";
                    detail: "612 KB · Completed";
                    percent: "Done";
                    progress: 1;
                    show-separator: false;
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.divider;
            }

            VerticalLayout {
                width: 360px;
                spacing: 0px;
                SectionLabel { label: "DEVICE"; meta: "Encrypted"; }
                DeviceRow {
                    height: 100px;
                    name: "Galaxy S24";
                    detail: "Android · Connected";
                }
                Rectangle {
                    height: 70px;
                    HorizontalLayout {
                        spacing: 16px;
                        Text {
                            text: "Speed";
                            color: Theme.text-faint;
                            font-family: "Segoe UI";
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text {
                            text: root.paused ? "—" : "38.4 MB/s";
                            color: Theme.text;
                            font-family: "Segoe UI";
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Theme.divider;
                    }
                }
                Rectangle {
                    height: 70px;
                    HorizontalLayout {
                        spacing: 16px;
                        Text {
                            text: "Elapsed";
                            color: Theme.text-faint;
                            font-family: "Segoe UI";
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text {
                            text: "00:06";
                            color: Theme.text;
                            font-family: "Consolas";
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 76px;
            border-radius: Metrics.radius;
            background: Theme.surface-soft;
            HorizontalLayout {
                padding-left: 20px;
                padding-right: 10px;
                spacing: 10px;
                Text {
                    text: root.paused ? "Paused safely" : "Direct encrypted transfer";
                    color: Theme.text-muted;
                    font-family: "Segoe UI";
                    font-size: 12px;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                QuietButton { label: "Cancel"; danger: true; }
                PrimaryButton {
                    width: 154px;
                    label: root.paused ? "Resume" : "Pause";
                    icon: root.paused ? "▶" : "Ⅱ";
                    clicked => { root.paused = !root.paused; }
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    in-out property <int> current-view: 0;
    callback close-requested;
    callback minimize-requested;
    callback maximize-requested;
    callback drag-requested;
    callback center-requested;

    title: "Eclipxse Beam";
    no-frame: true;
    resize-border-width: 7px;
    background: Theme.backdrop;
    preferred-width: 1180px;
    preferred-height: 760px;
    min-width: 1040px;
    min-height: 720px;
    default-font-family: "Segoe UI";
    default-font-size: 12px;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.canvas;
        border-width: 1px;
        border-color: Theme.edge;

        AppTitleBar {
            x: 0px;
            y: 0px;
            width: parent.width;
            current-view: root.current-view;
            navigate(view) => { root.current-view = view; }
            close-requested => { root.close-requested(); }
            minimize-requested => { root.minimize-requested(); }
            maximize-requested => { root.maximize-requested(); }
            drag-requested => { root.drag-requested(); }
        }

        Rectangle {
            x: 0px;
            y: Metrics.title-height;
            width: parent.width;
            height: parent.height - Metrics.title-height;
            background: Theme.canvas;

            SendView {
                visible: root.current-view == 0;
                width: parent.width;
                height: parent.height;
                start-transfer => { root.current-view = 2; }
            }
            ReceiveView {
                visible: root.current-view == 1;
                width: parent.width;
                height: parent.height;
            }
            TransferView {
                visible: root.current-view == 2;
                width: parent.width;
                height: parent.height;
            }
        }
    }

    init => { root.center-requested(); }
}
