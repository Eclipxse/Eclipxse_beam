import { Theme, Metrics } from "design-tokens.slint";
import {
    WindowControl, SegmentTab, IconButton, PrimaryButton, QuietButton,
    SectionLabel, DropCommand, FileRow, DeviceRow, ProgressBar, TransferRow
} from "components.slint";

component BrandMark inherits Rectangle {
    width: 34px;
    height: 34px;
    background: #00000000;

    Rectangle {
        x: 5px;
        y: 5px;
        width: 24px;
        height: 24px;
        border-radius: 12px;
        background: #00000000;
        border-width: 2px;
        border-color: Theme.cream;
    }
    Rectangle {
        x: 2px;
        y: 16px;
        width: 30px;
        height: 2px;
        border-radius: 1px;
        background: Theme.caramel;
    }
}

component AppTitleBar inherits Rectangle {
    in property <int> current-view: 0;
    callback navigate(int);
    callback close-requested;
    callback minimize-requested;
    callback maximize-requested;
    callback drag-requested;

    height: Metrics.title-height;
    background: Theme.canvas;

    drag-zone := TouchArea {
        width: parent.width - 252px;
        height: parent.height;
        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                root.drag-requested();
            }
        }
        double-clicked => { root.maximize-requested(); }
    }

    Rectangle {
        x: 26px;
        y: 19px;
        width: 220px;
        height: 34px;
        HorizontalLayout {
            spacing: 12px;
            BrandMark { }
            Text {
                text: "Eclipxse Beam";
                color: Theme.text;
                font-family: "Segoe UI";
                font-size: 15px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: 15px;
        width: 252px;
        height: 42px;
        border-radius: Metrics.radius-small;
        background: Theme.surface-soft;
        HorizontalLayout {
            spacing: 4px;
            padding-left: 2px;
            padding-right: 2px;
            SegmentTab {
                label: "Send";
                selected: root.current-view == 0 || root.current-view == 2;
                clicked => { root.navigate(0); }
            }
            SegmentTab {
                label: "Receive";
                selected: root.current-view == 1;
                clicked => { root.navigate(1); }
            }
        }
    }

    Rectangle {
        x: parent.width - 332px;
        y: 16px;
        width: 322px;
        height: 40px;
        HorizontalLayout {
            spacing: 5px;

            Rectangle {
                width: 86px;
                HorizontalLayout {
                    padding-left: 5px;
                    spacing: 8px;
                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: Theme.sage;
                    }
                    Text {
                        text: root.current-view == 2 ? "Sending" : "Ready";
                        color: Theme.text-muted;
                        font-family: "Segoe UI";
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }

            IconButton { glyph: "⚙"; }
            Rectangle { width: 8px; }
            WindowControl {
                glyph: "−";
                clicked => { root.minimize-requested(); }
            }
            WindowControl {
                glyph: "□";
                clicked => { root.maximize-requested(); }
            }
            WindowControl {
                glyph: "×";
                danger: true;
                clicked => { root.close-requested(); }
            }
        }
    }
}

component SendView inherits Rectangle {
    callback start-transfer;

    min-height: 688px;
    max-width: 10000px;
    max-height: 10000px;
    background: Theme.canvas;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: Metrics.content-padding;
        padding-right: Metrics.content-padding;
        padding-top: 20px;
        spacing: 0px;

        DropCommand { }
        Rectangle { height: 16px; }

        FileRow {
            thumb-kind: 0;
            name: "Midnight in Kyoto.mov";
            size: "184.2 MB";
        }
        FileRow {
            thumb-kind: 1;
            name: "Brand assets.zip";
            size: "63.8 MB";
        }
        FileRow {
            thumb-kind: 2;
            name: "beam-cover.png";
            size: "612 KB";
            show-separator: false;
        }

        SectionLabel {
            label: "NEARBY DEVICES";
            meta: "1 found";
        }

        DeviceRow { }

        Rectangle {
            height: 76px;
            border-radius: Metrics.radius;
            background: Theme.surface-soft;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 10px;
                spacing: 12px;
                Text {
                    text: "3 files · 248 MB";
                    color: Theme.text;
                    font-family: "Segoe UI";
                    font-size: 15px;
                    font-weight: 500;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                QuietButton { label: "Clear"; }
                PrimaryButton {
                    width: 174px;
                    label: "Beam files";
                    icon: "→";
                    clicked => { root.start-transfer(); }
                }
            }
        }
    }
}

component StepRow inherits HorizontalLayout {
    in property <string> number;
    in property <string> title;
    in property <string> detail;

    height: 68px;
    spacing: 14px;

    Rectangle {
        width: 30px;
        height: 30px;
        border-radius: 15px;
        background: Theme.accent-soft;
        Text {
            text: root.number;
            color: Theme.caramel;
            font-family: "Segoe UI";
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    VerticalLayout {
        spacing: 3px;
        Text {
            text: root.title;
            color: Theme.text;
            font-family: "Segoe UI";
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: bottom;
        }
        Text {
            text: root.detail;
            color: Theme.text-faint;
            font-family: "Segoe UI";
            font-size: 10px;
            vertical-alignment: top;
        }
    }
}

component ReceiveView inherits Rectangle {
    min-height: 688px;
    max-width: 10000px;
    max-height: 10000px;
    background: Theme.canvas;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: Metrics.content-padding;
        padding-right: Metrics.content-padding;
        padding-top: 20px;
        spacing: 0px;

        Rectangle {
            height: 104px;
            border-radius: Metrics.radius;
            background: Theme.surface-soft;
            HorizontalLayout {
                padding-left: 24px;
                padding-right: 22px;
                spacing: 16px;
                Text {
                    text: "↓";
                    color: Theme.cream;
                    font-family: "Segoe UI Symbol";
                    font-size: 30px;
                    vertical-alignment: center;
                }
                VerticalLayout {
                    spacing: 5px;
                    Text {
                        text: "Receive files";
                        color: Theme.text;
                        font-family: "Segoe UI";
                        font-size: 19px;
                        font-weight: 600;
                        vertical-alignment: bottom;
                    }
                    Text {
                        text: "Scan the code with your phone camera";
                        color: Theme.text-muted;
                        font-family: "Segoe UI";
                        font-size: 12px;
                        vertical-alignment: top;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "PAIRING CODE";
                        color: Theme.text-faint;
                        font-family: "Segoe UI";
                        font-size: 9px;
                        font-weight: 700;
                        letter-spacing: 1px;
                        horizontal-alignment: right;
                        vertical-alignment: bottom;
                    }
                    Text {
                        text: "7K9A-2F";
                        color: Theme.cream;
                        font-family: "Consolas";
                        font-size: 18px;
                        font-weight: 600;
                        letter-spacing: 1.2px;
                        horizontal-alignment: right;
                        vertical-alignment: top;
                    }
                }
            }
        }

        Rectangle { height: 16px; }

        HorizontalLayout {
            vertical-stretch: 1;
            max-height: 10000px;
            spacing: 30px;

            Rectangle {
                horizontal-stretch: 1;
                max-width: 10000px;
                background: #00000000;
                VerticalLayout {
                    alignment: center;
                    spacing: 14px;
                    HorizontalLayout {
                        height: 252px;
                        alignment: center;
                        Rectangle {
                            width: 252px;
                            height: 252px;
                            border-radius: 16px;
                            background: Theme.cream;
                            Image {
                                x: 13px;
                                y: 13px;
                                width: 226px;
                                height: 226px;
                                source: @image-url("assets/pairing-qr.png");
                                image-fit: contain;
                            }
